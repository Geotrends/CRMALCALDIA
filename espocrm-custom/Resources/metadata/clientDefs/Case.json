            "disabled": true
        },
        "actuosArchivo": {
            "disabled": true
        },
        "articles": {
            "disabled": true
        },
        "contacts": {
            "disabled": true
        },
        "contact": {
            "disabled": true
        },
        "account": {
            "disabled": true
        }
    },
    "sidePanels": {
        "edit": [],
        "detail": [
            {
                "name": "actaVisitaPanel",
                "label": "Acta de visita",
                "view": "custom:views/case/record/panels/acta-visita",
                "notRefreshable": true
            },
            {
                "name": "formatoSolicitud",
                "label": "Formato solicitud",
                "view": "custom:views/case/record/panels/formato-solicitud",
                "notRefreshable": true
            },
            {
                "name": "formatoActaVisita",
                "label": "Formato acta de visita",
                "view": "custom:views/case/record/panels/formato-acta-visita",
                "notRefreshable": true
            },
            {
                "name": "actuoArchivoPanel",
                "label": "Auto de archivo",
                "view": "custom:views/case/record/panels/actuo-archivo",
                "notRefreshable": true
            },
            {
                "name": "formatoActuoArchivo",
                "label": "Formato auto de archivo",
                "view": "custom:views/case/record/panels/formato-actuo-archivo",
                "notRefreshable": true
            },
            {
                "name": "activities",
                "disabled": true
            },
            {
                "name": "history",
                "disabled": true
            },
            {
                "name": "tasks",
                "disabled": true
            }
        ],
        "detailSmall": [
            {
                "name": "activities",
                "disabled": true
            },
            {
                "name": "history",
                "disabled": true
            },
            {
                "name": "tasks",
                "disabled": true
            }
        ]
    },
    "fields": {
        "assignedUser": {
            "view": "custom:views/case/fields/assigned-user"
        },
        "cRecibidaPor": {
            "primaryFilter": "recibidores"
        },
        "cRemitidoA": {
            "primaryFilter": "radicacion"
        }
    },
    "dynamicLogic": {
        "fields": {
            "assignedUser": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "and",
                            "value": [
                                {
                                    "type": "isNotEmpty",
                                    "attribute": "cNumeroRadicado"
                                },
                                {
                                    "type": "isNotEmpty",
                                    "attribute": "cExpediente"
                                }
                            ]
                        }
                    ]
                }
            }
        }
    }
}
